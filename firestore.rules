rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Comanda
    function isValidComanda(data, userId) {
      return data.keys().hasAll(['nome', 'itens', 'createdAt', 'userId']) &&
             data.keys().size() == 4 &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() <= 100 &&
             data.itens is list && data.itens.size() <= 100 &&
             data.createdAt is number &&
             data.userId == userId;
    }

    // Gasto
    function isValidGasto(data, userId) {
      return data.keys().hasAll(['descricao', 'valor', 'data', 'userId']) &&
             data.keys().size() == 4 &&
             data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 200 &&
             data.valor is number &&
             data.data is string && data.data.size() <= 50 &&
             data.userId == userId;
    }

    // ProdutoCardapio
    function isValidProdutoCardapio(data, userId) {
      return data.keys().hasAll(['nome', 'preco', 'userId']) &&
             data.keys().size() == 3 &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() <= 100 &&
             data.preco is number &&
             data.userId == userId;
    }

    // Caixa
    function isValidCaixa(data, userId) {
      return data.keys().hasAll(['Dinheiro', 'Pix', 'Cartão', 'userId']) &&
             data.keys().size() == 4 &&
             data.Dinheiro is number &&
             data.Pix is number &&
             data['Cartão'] is number &&
             data.userId == userId;
    }

    match /restaurante/onealgrill {
      match /comandas/{comandaId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidId(comandaId);
        allow update: if isAuthenticated() && isValidId(comandaId);
        allow delete: if isAuthenticated() && isValidId(comandaId);
      }

      match /gastos/{gastoId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidId(gastoId);
        allow update: if isAuthenticated() && isValidId(gastoId);
        allow delete: if isAuthenticated() && isValidId(gastoId);
      }

      match /cardapio/{cardapioId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidId(cardapioId);
        allow update: if isAuthenticated() && isValidId(cardapioId);
        allow delete: if isAuthenticated() && isValidId(cardapioId);
      }

      match /caixa/{caixaId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidId(caixaId) && caixaId == 'atual';
        allow update: if isAuthenticated() && isValidId(caixaId) && caixaId == 'atual';
        allow delete: if isAuthenticated() && isValidId(caixaId) && caixaId == 'atual';
      }
      
      match /rendimentos/{rendimentoId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated();
      }
    }
  }
}
